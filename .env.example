# ============================================================
# KELEMBA MOBILE — Variables d'environnement
# Copier ce fichier en .env.local et remplir les vraies valeurs
# NE JAMAIS COMMITER .env.local / .env.staging / .env.production
# ============================================================

# ── API Backend ──────────────────────────────────────────────
# API_URL doit se terminer par /api (PAS /api/v1)
# Le segment /v1 est ajouté dans endpoints.ts
EXPO_PUBLIC_API_URL=http://localhost:3000/api
EXPO_PUBLIC_API_TIMEOUT_MS=15000
EXPO_PUBLIC_API_VERSION=v1

# ── Authentification JWT ─────────────────────────────────────
EXPO_PUBLIC_ACCESS_TOKEN_TTL_MIN=15
EXPO_PUBLIC_REFRESH_TOKEN_TTL_DAYS=30

# ── Orange Money ─────────────────────────────────────────────
EXPO_PUBLIC_ORANGE_MONEY_BASE_URL=https://api.orange.com/orange-money-webpay/dev/v1
EXPO_PUBLIC_ORANGE_MONEY_MERCHANT_ID=MERCHANT_ID_ICI
# SECRET — Ne pas préfixer par EXPO_PUBLIC_ (non exposé au client)
ORANGE_MONEY_API_KEY=YOUR_ORANGE_MONEY_API_KEY
ORANGE_MONEY_WEBHOOK_SECRET=YOUR_ORANGE_WEBHOOK_HMAC_SECRET

# ── Telecel Money ────────────────────────────────────────────
EXPO_PUBLIC_TELECEL_MONEY_BASE_URL=https://api.telecel.cf/money/v1
EXPO_PUBLIC_TELECEL_MERCHANT_ID=MERCHANT_ID_ICI
TELECEL_MONEY_API_KEY=YOUR_TELECEL_API_KEY
TELECEL_MONEY_WEBHOOK_SECRET=YOUR_TELECEL_WEBHOOK_HMAC_SECRET

# ── Firebase (Notifications Push) ───────────────────────────
EXPO_PUBLIC_FIREBASE_PROJECT_ID=kelemba-digital
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:android:0000000000000000
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=kelemba-digital.firebaseapp.com
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=kelemba-digital.appspot.com

# ── Application ──────────────────────────────────────────────
EXPO_PUBLIC_APP_NAME=Kelemba
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_DEFAULT_LANG=fr
EXPO_PUBLIC_COUNTRY_CODE=+236
EXPO_PUBLIC_CURRENCY=FCFA

# ── Sécurité ─────────────────────────────────────────────────
EXPO_PUBLIC_PIN_LENGTH=6
EXPO_PUBLIC_MAX_LOGIN_ATTEMPTS=5
EXPO_PUBLIC_OTP_TTL_SECONDS=90
EXPO_PUBLIC_SESSION_TIMEOUT_MS=900000

# ── Tontine — Règles métier ──────────────────────────────────
EXPO_PUBLIC_MIN_CONTRIBUTION_FCFA=500
EXPO_PUBLIC_MAX_MEMBERS_PER_TONTINE=50

# ── Feature Flags ────────────────────────────────────────────
EXPO_PUBLIC_FEATURE_BIOMETRIC=true
EXPO_PUBLIC_FEATURE_OFFLINE_MODE=true
EXPO_PUBLIC_FEATURE_KYC_ENABLED=true
EXPO_PUBLIC_FEATURE_CHAT_ENABLED=false

# ── Monitoring / Sentry ──────────────────────────────────────
EXPO_PUBLIC_SENTRY_DSN=https://YOUR_SENTRY_DSN@sentry.io/0000000
EXPO_PUBLIC_SENTRY_ENV=development

# ── Stockage sécurisé — clés SecureStore ────────────────────
EXPO_PUBLIC_SECURE_KEY_ACCESS_TOKEN=kelemba_access_token
EXPO_PUBLIC_SECURE_KEY_REFRESH_TOKEN=kelemba_refresh_token
EXPO_PUBLIC_SECURE_KEY_PIN=kelemba_payment_pin
EXPO_PUBLIC_SECURE_KEY_BIOMETRIC=kelemba_biometric_enabled
EXPO_PUBLIC_SECURE_KEY_PIN_HASH=kelemba_pin_hash
EXPO_PUBLIC_SECURE_KEY_USER_ID=kelemba_user_id
EXPO_PUBLIC_SECURE_KEY_FCM_TOKEN=fcm_token
